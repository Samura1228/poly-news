# =====================================================================
# Polymarket News Bot — environment template
# Copy this file to `.env` and fill in the values:  cp .env.example .env
# The .env file is gitignored; this .env.example is safe to commit.
# =====================================================================

# REQUIRED — Get from @BotFather in Telegram (/newbot command)
# https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ---------------------- Polling ----------------------
# How often (minutes) to fetch news and dispatch to subscribers.
POLL_INTERVAL_MINUTES=30

# Delay (seconds) before the first fetch cycle runs after boot.
STARTUP_DELAY_SECONDS=30

# How far back (hours) to send historical news to a brand-new subscriber.
BACKFILL_WINDOW_HOURS=24

# Hard cap on items dispatched per user per cycle to prevent flooding.
MAX_ITEMS_PER_CYCLE=10

# ---------------------- Storage ----------------------
# SQLite database path (relative to working directory).
# LOCAL dev: keep as `./data/bot.db` (relative, ./data/ will be auto-created).
# RAILWAY: attach a Volume in the dashboard mounted at `/data` and set this to `/data/bot.db`
# (otherwise the database is wiped on every redeploy).
DATABASE_PATH=./data/bot.db

# Prune news items older than this many days.
NEWS_RETENTION_DAYS=30

# ---------------------- HTTP ----------------------
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT=PolyNewsBot/1.0 (+https://t.me/your_bot)

# ---------------------- Optional API keys ----------------------
# Leave any of these blank to disable that specific fetcher.

# CryptoPanic — ⚠️ PAID ONLY since April 1, 2026 (free Developer tier discontinued).
# If subscribing, choose a plan and set both vars below.
# Plans & pricing: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
# One of: developer | growth | enterprise — must match your paid plan.
CRYPTOPANIC_API_PLAN=developer

# NewsData.io — FREE tier (200 requests/day). Recommended replacement for CryptoPanic.
# Sign up: https://newsdata.io/register
# Get key at: https://newsdata.io/login (Dashboard -> API Key)
NEWSDATA_API_KEY=

# Mediastack — FREE tier (100 requests/month, low quota — secondary source).
# Sign up: https://mediastack.com/signup/free
MEDIASTACK_API_KEY=

# Twitter/X official API — PAID ($100/mo Basic plan). Nitter below is the free alternative.
# https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# GitHub — optional, only raises rate limit (60 -> 5000 req/hr). No scopes needed.
# https://github.com/settings/tokens  (Generate new token classic, no scopes)
GITHUB_TOKEN=

# ---------------------- Source toggles ----------------------
# Comma-separated source slugs to disable, e.g. "substack,medium".
DISABLED_SOURCES=

# ---------------------- Nitter (free Twitter mirror) ----------------------
# Comma-separated list of currently-working Nitter mirrors (no @).
# Status page: https://status.d420.de/
NITTER_MIRRORS=nitter.poast.org,nitter.privacydev.net,nitter.tiekoetter.com,nitter.salastil.com

# ---------------------- YouTube ----------------------
# Polymarket's YouTube channel ID (starts with UC...).
# Find it at https://www.youtube.com/@Polymarket -> View Page Source -> search "channelId"
# Or use https://commentpicker.com/youtube-channel-id.php
POLYMARKET_YOUTUBE_CHANNEL_ID=

# ---------------------- Logging ----------------------
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO